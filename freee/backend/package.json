{
  "name": "@freee/backend",
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": "./src/app.ts",
    "./app": "./src/app.ts"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:migrate": "tsx src/db/migrate.ts drizzle/0000_init.sql",
    "db:seed": "tsx src/db/migrate.ts drizzle/seed.sql"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.5",
    "@hono/zod-validator": "^0.8.0",
    "drizzle-orm": "^0.45.2",
    "hono": "^4.12.26",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.22.4",
    "vitest": "^4.1.9"
  }
}
