source "https://rubygems.org"

gem "rails", "~> 8.1.3"
gem "mysql2", "~> 0.5"
gem "puma", ">= 5.0"

gem "tzinfo-data", platforms: %i[ windows jruby ]

# Database-backed adapters (Solid Queue は ADR 0004 で webhook 配信に利用)
gem "solid_cache"
gem "solid_queue"

gem "bootsnap", require: false
gem "thruster", require: false

# CORS (frontend Next.js とクロスオリジン)
gem "rack-cors"

# Authentication: rodauth-rails + JWT bearer (perplexity と同じスタック)
gem "rodauth-rails"
gem "jwt"
gem "argon2"
gem "tilt", "~> 2.4", require: false
gem "sequel-activerecord_connection", "~> 2.0", require: false
gem "bcrypt", "~> 3.1", require: false

# Modular monolith: 各 Engine を path gem として読み込む (ADR 0001)
gem "core",      path: "components/core"
gem "catalog",   path: "components/catalog"
gem "inventory", path: "components/inventory"
gem "orders",    path: "components/orders"
gem "apps",      path: "components/apps"

# packwerk: Engine 間の依存方向を CI で強制 (ADR 0001)
gem "packwerk", require: false

group :development, :test do
  gem "debug", platforms: %i[ mri windows ], require: "debug/prelude"

  gem "bundler-audit", require: false
  gem "brakeman", require: false
  gem "rubocop-rails-omakase", require: false

  gem "rspec-rails", "~> 7.1"
  gem "factory_bot_rails"
end

group :test do
  gem "webmock", require: false
end
